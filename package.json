{
  "name": "soundboard-app",
  "version": "1.1.1",
  "description": "Soundboard desktop con routing audio e scorciatoie globali",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "electron scripts/render-icon.js",
    "build": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always"
  },
  "keywords": [],
  "author": "Inzi",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.soundboard.app",
    "productName": "Soundboard",
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "pinzis",
      "repo": "SoundBoardApp",
      "releaseType": "release"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icon.png"
    ]
  }
}
